# Copy this file to .env and fill in real values. NEVER commit the real .env.

# ----------------------------
# MongoDB (REQUIRED — app fails closed if unset)
# ----------------------------
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
DATABASE_NAME=voice_auth
COLLECTION_NAME=user_data

# ----------------------------
# Models
# ----------------------------
SPEAKER_VERIFIER_MODEL=speechbrain/spkrec-ecapa-voxceleb
# HuggingFace token for gated pyannote models
HF_AUTH_TOKEN=<your_huggingface_token>
# Speaker-embedding backend: ecapa (default) | campplus
# NOTE: switching backends requires re-enrolling all users (different
# embedding space/dim). CAM++ needs `pip install wespeaker` or `modelscope`.
EMBEDDING_BACKEND=ecapa
# wespeaker tag/local dir or modelscope id, e.g. iic/speech_campplus_sv_en_voxceleb_16k
CAMPLUS_MODEL=

# ----------------------------
# Thresholds / EWMA
# ----------------------------
VERIFICATION_THRESHOLD=0.50
EWMA_ENABLED=true
EWMA_ADAPTATION_THRESHOLD=0.70
EWMA_LEARNING_RATE=0.1

# ----------------------------
# Runtime
# ----------------------------
# cpu or cuda
DEVICE=cuda

# ----------------------------
# Security (Phase 0)
# ----------------------------
# Comma-separated API keys. If set, all API routes require an X-API-Key header.
# Leave unset ONLY for local development.
API_KEY=
# Comma-separated CORS origins allowed to call the API from a browser.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Max requests per minute per client IP (0 disables the in-memory limiter).
RATE_LIMIT_PER_MIN=60

# ----------------------------
# Anti-spoofing / liveness (Phase 3) — OFF until a checkpoint is validated
# ----------------------------
ANTISPOOF_ENABLED=false
# HF audio-classification spoof detector (e.g. an AASIST / wav2vec2 model).
ANTISPOOF_MODEL=
# Reject when P(spoof) >= threshold.
ANTISPOOF_THRESHOLD=0.5
# If the model can't load, reject (true) vs. allow (false).
ANTISPOOF_FAIL_CLOSED=true

# ----------------------------
# Performance (Phase 2)
# ----------------------------
# always = run VAD/diarization/separation every request (current behaviour)
# off    = skip the heavy multi-speaker pipeline (fast path; benchmark EER first)
HEAVY_PIPELINE_MODE=always
# CUDA mixed-precision (fp16) inference; no-op on CPU.
USE_AMP=true
